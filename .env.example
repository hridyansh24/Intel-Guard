LLM_PROVIDER=openai              # openai | anthropic | gemini
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o                 # primary model — used for detection, quiz generation, summary
LLM_MODEL_MINI=gpt-4o-mini       # cheap model — used for evaluating quiz answers

# PostgreSQL — use Supabase, Neon, or local Postgres
# Supabase: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Neon: postgresql+asyncpg://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require
DATABASE_URL=postgresql+asyncpg://localhost/ai_guard
